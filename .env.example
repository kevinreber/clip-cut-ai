VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Required by @convex-dev/auth for signing session JWTs
# Set this in your Convex dashboard under Settings > Environment Variables
# Generate with: npx @convex-dev/auth
JWT_PRIVATE_KEY=

# Required by @convex-dev/auth for OAuth redirect URLs
# Set this in your Convex dashboard under Settings > Environment Variables
# Should be your production frontend URL (e.g., https://your-app-domain.com)
SITE_URL=https://your-app-domain.com

# Google OAuth (set these in your Convex dashboard under Settings > Environment Variables)
# Get credentials from https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# OpenAI API key for video analysis (set in Convex dashboard)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key
